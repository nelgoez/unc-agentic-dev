{
  "name": "unc-agentic-dev",
  "type": "module",
  "version": "0.1.0",
  "description": "UNC Campus Virtual — Agentic dev infrastructure for Moodle automation, reengagement & diploma tracking",
  "license": "ISC",
  "scripts": {
    "opencode": "dotenv -e .env -- opencode",
    "setup": "bun cli/doctor.ts --preflight && bun cli/install.ts",
    "setup:doctor": "bun cli/doctor.ts",
    "vars:check": "bun scripts/lint-vars.ts",
    "format:fix": "prettier --write \"**/*.{json,jsonc,yml,yaml,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{json,jsonc,yml,yaml,css,md}\" --ignore-path .prettierignore",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "types:check": "tsc --noEmit",
    "create:curso": "bun packages/unc-course-kit/src/index.ts",
    "test": "playwright test",
    "test:allure": "ALLURE_DIR=allure-results playwright test",
    "report:generate": "bun scripts/generate-evidence-report.ts",
    "allure:generate": "bunx allure generate allure-results --clean -o allure-report",
    "allure:open": "bunx allure open allure-report",
    "repo:check": "bun run format:check && bun run lint:check && bun run types:check && bun run vars:check",
    "ci:check": "bun run types:check && bun run vars:check",
    "repo:fix": "bun run format:fix && bun run lint:fix",
    "clean": "rm -rf node_modules dist",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.16.0",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.9.3",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.61.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,jsonc,yml,yaml,css,md}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  },
  "dependencies": {
    "pptxgenjs": "^4.0.1"
  }
}
