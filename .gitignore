dist/
build/
*.tsbuildinfo

# Environment
.env
.env.local
*.tmp

# IDE & Editor
.idea/
.windsurf/
.cursor/
*.swp
*.swo
*.code-workspace

# OS Files
.DS_Store
Thumbs.db
nul

# Vercel
.vercel

# AI CLI Tools
.serena
.gemini/
.backups/

# Local config overrides
.mcp.local.json
opencode.local.jsonc
dbhub.toml

# Playwright / Test artifacts
playwright-report/
test-results/

# Planning / scratch
.scratch/

# SDD sprint artifacts
.superpowers/

# Local Netlify folder
.netlify

# Allure reports
allure-results/
allure-report/

# Graphify knowledge graph
graphify-out/

# Generated reports (audits, evidence, screenshots)
/reports/

# Playwright cache
playwright/.cache/
playwright/.auth/
